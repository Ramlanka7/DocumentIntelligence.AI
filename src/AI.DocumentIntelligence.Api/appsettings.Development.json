{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId,-36} {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "Anthropic": {
    "ApiKey": "<set-via-user-secrets>",
    "Model": "claude-sonnet-4-6"
  },

  "OpenAI": {
    "ApiKey": "<set-via-user-secrets>",
    "EmbeddingModel": "text-embedding-3-small"
  },

  "AzureOpenAI": {
    "Endpoint": "https://<your-resource>.openai.azure.com/",
    "ApiKey": "<set-via-user-secrets>",
    "ChatDeployment": "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-small",
    "EmbeddingDimensions": 1536
  },

  "AzureSearch": {
    "Endpoint": "https://<your-resource>.search.windows.net",
    "ApiKey": "<set-via-user-secrets>",
    "IndexName": "document-chunks-dev",
    "SemanticConfigurationName": "document-chunks-semantic",
    "VectorDimensions": 1536
  },

  "Chunking": {
    "ChunkSize": 800,
    "ChunkOverlap": 150,
    "SectionAware": true,
    "MinChunkSize": 30
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=docIntelligence_dev;Username=postgres;Password=postgres"
  }
}
