# Copy to `.env` for local `docker compose up`. Never commit the real `.env`.

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=document_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- Azurite (Azure Storage emulator) ---------------------------------------
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# --- Api ----------------------------------------------------------------------
API_HTTP_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=document_intelligence;Username=postgres;Password=postgres
ConnectionStrings__BlobStorage=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;

# --- Azure OpenAI (Microsoft Foundry) — leave blank locally, use Ollama/dev provider ---
AzureOpenAI__Endpoint=
AzureOpenAI__ApiKey=
AzureOpenAI__DeploymentName=

# --- Azure AI Search (placeholder — see ai-search-stub service in compose) --
AzureSearch__Endpoint=
AzureSearch__ApiKey=
AzureSearch__IndexName=documents

# --- Frontend -------------------------------------------------------------------
FRONTEND_HTTP_PORT=4200
