# ---------------------------------------------------------------------------
# Template for local docker compose development.
#
# SETUP: cp .env.example .env   (once)
#        Edit .env — fill in any blank values you need.
#        NEVER commit .env to the repository.
# ---------------------------------------------------------------------------

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=document_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---- Azurite (Azure Storage emulator) -------------------------------------
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# ---- JWT authentication ----------------------------------------------------
# Jwt__SecretKey MUST be at least 32 characters (256 bits) for HS256.
# Generate a strong random value: openssl rand -base64 48
# This key MUST match between the api service and any external token issuer.
Jwt__Issuer=DocumentIntelligence
Jwt__Audience=DocumentIntelligenceClient
Jwt__SecretKey=REPLACE_WITH_STRONG_256BIT_SECRET_KEY_AT_LEAST_32_CHARS
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# ---- API -------------------------------------------------------------------
API_HTTP_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=document_intelligence;Username=postgres;Password=postgres
ConnectionStrings__BlobStorage=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;

# ---- Azure OpenAI (Microsoft Foundry) -------------------------------------
# Leave blank locally to fall back to the stub/Ollama AI provider.
AzureOpenAI__Endpoint=
AzureOpenAI__ApiKey=
AzureOpenAI__ChatDeployment=gpt-4o
AzureOpenAI__EmbeddingDeployment=text-embedding-3-small
AzureOpenAI__EmbeddingDimensions=1536

# ---- Azure AI Search -------------------------------------------------------
# Leave blank locally; the API falls back to pgvector-only search.
AzureSearch__Endpoint=
AzureSearch__ApiKey=
AzureSearch__IndexName=document-chunks

# ---- Application Insights (optional) --------------------------------------
ApplicationInsights__ConnectionString=

# ---- Frontend --------------------------------------------------------------
FRONTEND_HTTP_PORT=4200
